# Set to "false" (or remove) to hit a real backend instead of mocks.
EXPO_PUBLIC_USE_MOCKS=true

# Base URL for the PesaFi Next.js API. Leave empty when using mocks.
# Example for local dev:  http://192.168.1.10:3000
# Example for prod:        https://pesafi.ai
EXPO_PUBLIC_API_BASE_URL=

# Supabase (used directly by the auth client when wired up)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
