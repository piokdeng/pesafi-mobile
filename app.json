{
  "expo": {
    "name": "PesaFi",
    "slug": "pesafi",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pesafi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#08101D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.pesafi.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PesaFi uses your camera to scan wallet QR codes for sending money.",
        "NSContactsUsageDescription": "PesaFi can use your contacts to make sending money to friends easier."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#08101D"
      },
      "package": "ai.pesafi.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PesaFi to access your camera to scan QR codes."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "",
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "router": {},
      "eas": {
        "projectId": "39fd0646-db74-470a-99f2-59b6d1260221"
      }
    },
    "owner": "piok_mei",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/39fd0646-db74-470a-99f2-59b6d1260221"
    }
  }
}
